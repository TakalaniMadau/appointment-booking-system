{
  "name": "@appointment/api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:deploy": "node --env-file-if-exists=../../.env ./node_modules/prisma/build/index.js migrate deploy",
    "db:generate": "node --env-file-if-exists=../../.env ./node_modules/prisma/build/index.js generate",
    "db:migrate": "node --env-file-if-exists=../../.env ./node_modules/prisma/build/index.js migrate dev",
    "db:seed": "node --env-file-if-exists=../../.env --import tsx prisma/seed.ts",
    "db:studio": "node --env-file-if-exists=../../.env ./node_modules/prisma/build/index.js studio",
    "dev": "node --env-file-if-exists=../../.env --watch --watch-preserve-output --import tsx src/server.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node --env-file-if-exists=../../.env dist/server.js",
    "test": "node --import tsx --test src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@appointment/shared": "workspace:*",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^6.19.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.1",
    "pino": "^10.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "prisma": "^6.19.0",
    "tsx": "^4.20.6",
    "typescript": "~6.0.2"
  }
}
